rules_version = '2';

// Regras Firestore — Abächerly Licitações
//
// HIERARQUIA OFICIAL:
//   adm_tecnico (topo)  - acesso total, incluindo configuracoes e treinamento do agente IA
//   adm_geral           - tudo MENOS configuracoes e treinamento (gestor da Abacherly)
//   analista            - operacoes basicas
//   cliente             - apenas seus proprios dados
//
// Roles legados (retrocompat ate todos docs migrarem):
//   super_admin -> adm_tecnico
//   admin       -> adm_geral
//   operator    -> analista
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPERS ====================
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDoc().role;
    }

    function userClientId() {
      return userDoc().clientId;
    }

    // adm_tecnico = topo da hierarquia (inclui legado super_admin)
    function isAdmTecnico() {
      return isSignedIn() && (userRole() == 'adm_tecnico' || userRole() == 'super_admin');
    }

    // adm_geral = gestor (inclui legado admin)
    function isAdmGeral() {
      return isSignedIn() && (userRole() == 'adm_geral' || userRole() == 'admin');
    }

    // Qualquer admin (tecnico ou geral) — gestao
    function isAdmin() {
      return isAdmTecnico() || isAdmGeral();
    }

    function isAnalista() {
      return isSignedIn() && (userRole() == 'analista' || userRole() == 'operator');
    }

    // Toda a equipe Abacherly (admins + analistas)
    function isEquipe() {
      return isAdmin() || isAnalista();
    }

    function isCliente() {
      return isSignedIn() && userRole() == 'cliente';
    }

    function isOwnerOfClient(clientId) {
      return isCliente() && userClientId() == clientId;
    }

    // ==================== USERS ====================
    // Cada usuário lê seu próprio doc; admins gerenciam os demais
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if isAdmTecnico();
    }

    // ==================== LICITAÇÕES ====================
    // Equipe lê/escreve todas; cliente só as suas
    match /licitacoes/{id} {
      allow read: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow create: if isEquipe() || isOwnerOfClient(request.resource.data.clientId);
      allow update: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow delete: if isAdmin();
    }

    // ==================== EVENTOS / AGENDA ====================
    match /eventos/{id} {
      allow read: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow create, update, delete: if isEquipe();
    }

    // ==================== CERTIDÕES ====================
    match /certidoes/{id} {
      allow read: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow create, update: if isEquipe() || isOwnerOfClient(request.resource.data.clientId);
      allow delete: if isAdmin();
    }

    // ==================== PAGAMENTOS ====================
    match /pagamentos/{id} {
      allow read: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow create, update: if isEquipe();
      allow delete: if isAdmin();
    }

    // ==================== SOLICITAÇÕES (cliente pede análise) ====================
    match /solicitacoes/{id} {
      allow read: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow create: if isCliente() && request.resource.data.clientId == userClientId();
      allow update: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow delete: if isAdmin();
    }

    // ==================== DOCUMENTOS ====================
    match /documentos/{id} {
      allow read: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow create: if isSignedIn() && (
        isEquipe() ||
        (isCliente() && request.resource.data.clientId == userClientId())
      );
      allow update: if isEquipe() || isOwnerOfClient(resource.data.clientId);
      allow delete: if isAdmin();
    }

    // ==================== CLIENTES (info empresa) ====================
    match /clientes/{clientId} {
      allow read: if isEquipe() || isOwnerOfClient(clientId);
      allow create, update: if isAdmin() || isOwnerOfClient(clientId);
      allow delete: if isAdmTecnico();
    }

    // ==================== RELATÓRIOS ====================
    match /relatorios/{id} {
      allow read: if isEquipe() || (
        isOwnerOfClient(resource.data.clientId) && resource.data.liberadoParaCliente == true
      );
      allow create, update: if isEquipe();
      allow delete: if isAdmin();
    }

    // ==================== ANÁLISES IA (agente) ====================
    // Geradas pelo Cloud Run. Equipe gerencia, cliente lê só as suas (quando liberadas).
    match /analises_ia/{id} {
      allow read: if isEquipe() || (
        isOwnerOfClient(resource.data.clientId) && resource.data.liberadoParaCliente == true
      );
      allow create, update: if isEquipe();
      allow delete: if isAdmin();
    }

    // ==================== CONFIGURAÇÕES SISTEMA ====================
    // Acesso restrito ao adm_tecnico (configs gerais + retencao do agente IA)
    match /configuracoes/{id} {
      allow read: if isEquipe();
      allow write: if isAdmTecnico();
    }

    // ==================== EXEMPLOS DE ANÁLISE (treino do agente IA) ====================
    // Apenas adm_tecnico — treinamento do agente é exclusivo do tecnico
    match /exemplos_analise/{id} {
      allow read: if isEquipe();
      allow create, update, delete: if isAdmTecnico();
    }
  }
}
